# Copy this to .env.local and fill in real values.
# Convex env vars (MOOLRE_*, BREVO_API_KEY, QR_SIGNING_SECRET) must ALSO be
# set on the Convex deployment itself, since convex/*.ts runs server-side:
#   npx convex env set MOOLRE_API_KEY your_key_here
#   npx convex env set MOOLRE_API_BASE https://api.moolre.com
#   npx convex env set BREVO_API_KEY your_key_here
#   npx convex env set QR_SIGNING_SECRET $(openssl rand -hex 32)
#   npx convex env set CONVEX_SITE_URL https://your-deployment.convex.site

# --- Clerk ---
CLERK_FRONTEND_API_URL=https://REPLACE_ME.clerk.accounts.dev
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# --- Moolre ---
# Confirm exact env var names / endpoint paths against Moolre's current
# developer docs before going live - this project assumes a generic
# REST collection + SMS API shape.
MOOLRE_API_BASE=https://api.moolre.com
MOOLRE_API_KEY=REPLACE_ME

# --- Brevo ---
BREVO_API_KEY=REPLACE_ME

# --- Internal ---
# Used to sign/verify ticket QR tokens. Generate with:
#   openssl rand -hex 32
QR_SIGNING_SECRET=REPLACE_ME

# The public URL of your Convex HTTP actions deployment (ends in
# .convex.site, NOT .convex.cloud), used to build the Moolre webhook
# callback URL.
CONVEX_SITE_URL=https://REPLACE_ME.convex.site
