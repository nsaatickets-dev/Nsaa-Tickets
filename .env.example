# Copy this to .env.local and fill in real values.
# Convex env vars (MOOLRE_*, BREVO_API_KEY, QR_SIGNING_SECRET) must ALSO be
# set on the Convex deployment itself, since convex/*.ts runs server-side:
#   npx convex env set CLERK_FRONTEND_API_URL https://your-clerk-url
#   npx convex env set MOOLRE_API_BASE https://sandbox.moolre.com
#   npx convex env set MOOLRE_API_USER your_username
#   npx convex env set MOOLRE_API_KEY your_private_key
#   npx convex env set MOOLRE_API_PUBKEY your_public_key
#   npx convex env set MOOLRE_VASKEY your_vas_key
#   npx convex env set MOOLRE_ACCOUNT_NUMBER your_moolre_account_number
#   npx convex env set MOOLRE_SMS_SENDER_ID your_approved_sender_id
#   npx convex env set BREVO_API_KEY your_key_here
#   npx convex env set QR_SIGNING_SECRET $(openssl rand -hex 32)
#   npx convex env set ADMIN_SECRET $(openssl rand -hex 32)
#
# Your Moolre webhook URL is your deployment's HTTP actions URL (shown by
# `npx convex dev` / the Convex dashboard, ends in .convex.site) plus
# /moolre/webhook - e.g. https://adjoining-aardvark-475.convex.site/moolre/webhook.
# Register that once in the Moolre dashboard's account settings (or via
# POST /open/account/update's `callback` field), not as an env var here.

# --- Clerk ---
CLERK_FRONTEND_API_URL=https://REPLACE_ME.clerk.accounts.dev
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# --- Moolre ---
# Verified against docs.moolre.com. Use https://sandbox.moolre.com while
# testing (only MOOLRE_API_USER is required there) and
# https://api.moolre.com once you're live (all keys required).
MOOLRE_API_BASE=https://sandbox.moolre.com
MOOLRE_API_USER=REPLACE_ME
MOOLRE_API_KEY=REPLACE_ME
MOOLRE_API_PUBKEY=REPLACE_ME
MOOLRE_VASKEY=REPLACE_ME
MOOLRE_ACCOUNT_NUMBER=REPLACE_ME
# Must be a Sender ID already registered + approved in the Moolre
# dashboard (max 11 chars) - SMS sends fail with code ASMS07 otherwise.
MOOLRE_SMS_SENDER_ID=REPLACE_ME

# --- Brevo ---
BREVO_API_KEY=REPLACE_ME

# --- Internal ---
# Used to sign/verify ticket QR tokens. Generate with:
#   openssl rand -hex 32
QR_SIGNING_SECRET=REPLACE_ME

# Gates payouts:initiateOrganizerPayout and events:setOrganizerTierAdmin -
# there's no real admin-role system yet, so this is the only thing
# stopping anyone with your deployment URL from calling them directly.
# Generate with: openssl rand -hex 32
ADMIN_SECRET=REPLACE_ME
